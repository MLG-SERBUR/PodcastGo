<Page
    x:Class="PodcastGo.AddPodcastPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PodcastGo"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <StackPanel Margin="24" MaxWidth="600" HorizontalAlignment="Left" VerticalAlignment="Top">
        <TextBlock Text="Add Podcast" FontSize="32" FontWeight="SemiBold" Margin="0,0,0,24"/>
        <TextBlock Text="Enter the RSS Feed URL:" Margin="0,0,0,8"/>
        <TextBox x:Name="UrlTextBox" PlaceholderText="https://example.com/feed.xml" Margin="0,0,0,16"/>
        <Button Content="Add Podcast" Click="AddPodcast_Click" Style="{StaticResource AccentButtonStyle}" Padding="24,8"/>
        <TextBlock x:Name="StatusTextBlock" Margin="0,16,0,0" Foreground="Red" Visibility="Collapsed"/>
    </StackPanel>
</Page>
