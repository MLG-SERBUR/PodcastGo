<Page
    x:Class="PodcastGo.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PodcastGo"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="Narrow">
                    <VisualState.StateTriggers>
                        <!-- Triggers when width is below 800px -->
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="NowPlayingGrid.Padding" Value="8,4" />
                        <!-- Collapse the text so the media player gets the full space -->
                        <Setter Target="NowPlayingTextPanel.Visibility" Value="Collapsed" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Wide">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="800" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="NowPlayingTextPanel.Visibility" Value="Visible" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- CommandBar (Windows Phone / Windows 8 style) -->
        <CommandBar x:Name="AppCommandBar" Grid.Row="0" DefaultLabelPosition="Right">
            <CommandBar.Content>
                <TextBlock x:Name="PageTitle" Text="PodcastGo" FontSize="16" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
            </CommandBar.Content>

            <AppBarButton x:Name="AddButton" Icon="Add" Label="Add Podcast" Click="AddButton_Click"/>

            <CommandBar.SecondaryCommands>
                <AppBarButton x:Name="ExportButton" Icon="Save" Label="Export" Click="ExportButton_Click"/>
                <AppBarButton x:Name="ImportButton" Icon="OpenFile" Label="Import" Click="ImportButton_Click"/>
                <AppBarButton x:Name="DebugButton" Icon="Repair" Label="Debug" Click="DebugButton_Click"/>
            </CommandBar.SecondaryCommands>
        </CommandBar>

        <!-- Main Content Area -->
        <Frame x:Name="ContentFrame" Grid.Row="1"/>

        <!-- Global Now Playing Bar -->
        <Border x:Name="NowPlayingBar" Grid.Row="2" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}"
                Visibility="Collapsed" BorderBrush="Gray" BorderThickness="0,1,0,0" Tapped="NowPlayingBar_Tapped">
            <Grid x:Name="NowPlayingGrid" Padding="16,8">
                <Grid.ColumnDefinitions>
                    <!-- Text column shrinks to 0 width seamlessly when Collapsed -->
                    <ColumnDefinition x:Name="TextColumn" Width="Auto"/>
                    <!-- Media player takes over the remainder perfectly -->
                    <ColumnDefinition x:Name="PlayerColumn" Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel x:Name="NowPlayingTextPanel" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock x:Name="NowPlayingTitle" FontSize="16" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="Now Playing" FontSize="14" Foreground="Gray"/>
                </StackPanel>

                <MediaPlayerElement x:Name="GlobalPlayer" Grid.Column="1" AreTransportControlsEnabled="True" Height="100" AutoPlay="True" HorizontalAlignment="Stretch"/>
            </Grid>
        </Border>
    </Grid>
</Page>