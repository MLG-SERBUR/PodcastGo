<Page
    x:Class="PodcastGo.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PodcastGo"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <!-- The VisualStateManager correctly placed inside the root Grid to actually execute -->
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="Narrow">
                    <VisualState.StateTriggers>
                        <!-- Triggers when width is below 800px -->
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="RootSplitView.DisplayMode" Value="Overlay" />
                        <Setter Target="NowPlayingGrid.Padding" Value="8,4" />
                        <!-- Collapse the text so the media player gets the full space -->
                        <Setter Target="NowPlayingTextPanel.Visibility" Value="Collapsed" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Wide">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="800" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="RootSplitView.DisplayMode" Value="CompactOverlay" />
                        <Setter Target="NowPlayingTextPanel.Visibility" Value="Visible" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Hamburger Button Row (Always visible) -->
        <Button x:Name="HamburgerButton" Grid.Row="0"
                FontFamily="Segoe MDL2 Assets" Content="&#xE700;"
                Width="48" Height="48" Background="Transparent"
                Click="HamburgerButton_Click"
                VerticalAlignment="Stretch" HorizontalAlignment="Left"
                BorderThickness="0"/>

        <!-- Main Content Area -->
        <SplitView x:Name="RootSplitView" Grid.Row="1"
                   DisplayMode="CompactOverlay"
                   OpenPaneLength="240"
                   CompactPaneLength="48"
                   IsPaneOpen="False">
            <SplitView.Pane>
                <ListView x:Name="NavListView" 
                           SelectionMode="Single" SelectionChanged="NavListView_SelectionChanged">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="MinWidth" Value="48"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListViewItem Tag="podcasts">
                        <StackPanel Orientation="Horizontal">
                            <Grid Width="48" Height="48">
                                <SymbolIcon Symbol="List"/>
                            </Grid>
                            <TextBlock Text="My Podcasts" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </StackPanel>
                    </ListViewItem>
                    <ListViewItem Tag="add">
                        <StackPanel Orientation="Horizontal">
                            <Grid Width="48" Height="48">
                                <SymbolIcon Symbol="Add"/>
                            </Grid>
                            <TextBlock Text="Add Podcast" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </StackPanel>
                    </ListViewItem>
                    <ListViewItem Tag="debug">
                        <StackPanel Orientation="Horizontal">
                            <Grid Width="48" Height="48">
                                <SymbolIcon Symbol="Setting"/>
                            </Grid>
                            <TextBlock Text="Debug" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </StackPanel>
                    </ListViewItem>
                </ListView>
            </SplitView.Pane>

            <SplitView.Content>
                <Frame x:Name="ContentFrame" />
            </SplitView.Content>
        </SplitView>

        <!-- Global Now Playing Bar -->
        <Border x:Name="NowPlayingBar" Grid.Row="2" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}"
                Visibility="Collapsed" BorderBrush="Gray" BorderThickness="0,1,0,0" Tapped="NowPlayingBar_Tapped">
            <Grid x:Name="NowPlayingGrid" Padding="16,8">
                <Grid.ColumnDefinitions>
                    <!-- Text column shrinks to 0 width seamlessly when Collapsed -->
                    <ColumnDefinition x:Name="TextColumn" Width="Auto"/>
                    <!-- Media player takes over the remainder perfectly -->
                    <ColumnDefinition x:Name="PlayerColumn" Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel x:Name="NowPlayingTextPanel" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock x:Name="NowPlayingTitle" FontSize="16" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="Now Playing" FontSize="14" Foreground="Gray"/>
                </StackPanel>

                <MediaPlayerElement x:Name="GlobalPlayer" Grid.Column="1" AreTransportControlsEnabled="True" Height="100" AutoPlay="True" HorizontalAlignment="Stretch"/>
            </Grid>
        </Border>
    </Grid>
</Page>